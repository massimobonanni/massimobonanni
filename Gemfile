source "https://rubygems.org"

# Use the github-pages gem so the local build matches GitHub Pages exactly.
# It bundles Jekyll, the "minima" theme and the "jekyll-readme-index" plugin
# (which renders README.md as the site index).
gem "github-pages", group: :jekyll_plugins

# Required for local `jekyll serve` on Ruby 3.x
gem "webrick", "~> 1.8"
